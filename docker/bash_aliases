# clean all docker files
_docker_clean() {
	echo "Cleaning up Docker resources..."
	docker images | grep "localhost:" | awk '{print $3}' | xargs docker rmi -f 2>/dev/null || true
	docker rm -f $(docker ps -aq) 2>/dev/null || true
	docker rmi -f $(docker images -aq) 2>/dev/null || true
	docker volume prune -f 2>/dev/null || true
	docker network prune -f 2>/dev/null || true
	docker system prune -a -f --volumes 2>/dev/null || true
	echo "✓ Docker cleanup completed"
}


alias dclean=_docker_clean

# clean all podman resources
_podman_clean() {
    # Verify podman machine is running
    if ! podman machine inspect 2>/dev/null | grep -q '"State": "running"'; then
        echo "✗ Podman machine is not running. Start it with: pm-start"
        return 1
    fi

    echo "Cleaning up Podman resources..."
    podman rm -f $(podman ps -aq) 2>/dev/null || true
    podman system prune -a -f --volumes 2>/dev/null || true
    echo "✓ Podman cleanup completed"
}

alias pm-clean=_podman_clean

# clean all docker resources on colima
_colima_clean() {
    # Verify colima is running
    if ! colima status 2>/dev/null | grep -q "colima is running"; then
        echo "✗ Colima is not running. Start it with: colima start"
        return 1
    fi

    # Get socket path directly from colima to avoid DOCKER_HOST/context conflicts
    local socket
    socket=$(colima status 2>/dev/null | grep -o 'docker socket: [^ ]*' | awk '{print $3}')
    : "${socket:=${XDG_CONFIG_HOME:-$HOME/.config}/colima/default/docker.sock}"

    echo "Cleaning up Docker resources on colima (socket: $socket)..."
    DOCKER_HOST="unix://$socket" docker rm -f $(DOCKER_HOST="unix://$socket" docker ps -aq) 2>/dev/null || true
    DOCKER_HOST="unix://$socket" docker system prune -a -f --volumes 2>/dev/null || true
    echo "✓ Colima Docker cleanup completed"
}

alias colima-clean=_colima_clean

# ctop needs TERM fix for tmux-256color
alias ctop='TERM=xterm-256color command ctop'

# ctop for Podman - use Podman socket
alias pm-ctop='TERM=xterm-256color DOCKER_HOST="unix://$(podman machine inspect --format "{{.ConnectionInfo.PodmanSocket.Path}}" 2>/dev/null)" command ctop'

# Podman machine management
alias pm-init='podman machine init --cpus 4 --memory 4096 --disk-size 50'
alias pm-start='podman machine set --rootful podman-machine-default && podman machine start'
alias pm-stop='podman machine stop'
