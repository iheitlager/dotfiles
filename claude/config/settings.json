{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Bash(tmux:*)",
      "Bash(podman:*)",
      "Bash(uv:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(echo:*)",
      "Bash(date:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(cd:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(rm -f:*)",
      "Bash(ln:*)",
      "Bash(touch:*)",
      "Bash(chmod:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(realpath:*)",
      "Bash(diff:*)",
      "Bash(python*)",
      "Bash(pip:*)",
      "Bash(cargo:*)",
      "Bash(brew:*)",
      "Bash(make:*)",
      "Bash(sleep:*)",
      "Bash(* --version)",
      "mcp__*",
      "Bash(npm *)",
      "Bash(*-h*)",
      "Bash(swarm-job:*)",
      "Bash(swarm-daemon:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(curl|*sh:*)",
      "Bash(wget|*sh:*)",
      "Bash(*>/dev/tcp/*)",
      "Bash(*base64*decode*)",
      "Bash(chmod 777:*)",
      "Bash(sudo:*)",
      "Bash(nc -:*)",
      "Bash(crontab:*)",
      "Bash(*LaunchAgents*)",
      "Bash(*LaunchDaemons*)",
      "Write(~/.ssh/*)",
      "Write(~/.aws/*)",
      "Write(~/.config/secrets)",
      "Write(/etc/*)",
      "Write(~/.crontab)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "swarm-hook register"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Edit|Write|Bash|Grep|Glob|Task",
        "hooks": [
          {
            "type": "command",
            "command": "swarm-hook hook"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "teammateMode": "tmux",
  "additionalDirectories": [
    ".",
    "~/.local/state/agent-context",
    "~/.dotfiles",
    "~/wc/**",
    "/workspace/**"
  ]
}
